# Anthropic (optional — reflect route)
ANTHROPIC_API_KEY=your_key_here

# Notion OAuth (public integration — required for user-owned export)
# Create a Public integration at https://www.notion.so/my-integrations
# Redirect URI: https://design-buddy-proxy.vercel.app/api/notion-oauth/callback
NOTION_CLIENT_ID=your_oauth_client_id
NOTION_CLIENT_SECRET=your_oauth_client_secret
NOTION_REDIRECT_URI=https://design-buddy-proxy.vercel.app/api/notion-oauth/callback

# DEPRECATED — remove from production Vercel (exports went to developer workspace only)
# NOTION_INTEGRATION_TOKEN=
# NOTION_PARENT_PAGE_ID=
